// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: detectives
// Document ID: {detectiveId} (Auth UID)
// Fields:
//   - uid: string (required) - The Auth UID
//   - displayName: string (required) - Detective name
//   - totalScore: number (required) - Cumulative score
//   - casesSolved: number (required) - Count of solved cases
//   - casesAttempted: number (required) - Count of attempted cases
//   - badges: list (optional) - List of badge strings
//   - lastUpdated: string (optional) - ISO date string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'totalScore', 'casesSolved', 'casesAttempted']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.totalScore is int && data.totalScore >= 0 &&
             data.casesSolved is int && data.casesSolved >= 0 &&
             data.casesAttempted is int && data.casesAttempted >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /detectives/{detectiveId} {
      allow read: if isOwner(detectiveId);
      allow create: if isOwner(detectiveId) && isValidProfile(request.resource.data);
      allow update: if isOwner(detectiveId) && isValidProfile(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid;
      allow delete: if false; // Profiles are persistent
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
